{
  "name": "@rkeelan/scriptum",
  "version": "0.1.0",
  "description": "Browser-based handwriting synthesis using Alex Graves' RNN model",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun run tsc",
    "check": "biome check .",
    "fmt": "biome check --fix .",
